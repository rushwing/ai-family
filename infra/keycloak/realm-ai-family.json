{
  "realm": "ai-family",
  "enabled": true,
  "sslRequired": "none",
  "accessTokenLifespan": 10,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "家长/管理者"
      },
      {
        "name": "adult",
        "description": "成人成员"
      },
      {
        "name": "kid",
        "description": "未成年成员（受 Compliance 守护）"
      }
    ]
  },
  "clients": [
    {
      "clientId": "ai-family-chatui",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "*"
      ],
      "webOrigins": [
        "*"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "aud-ai-family-chatui",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "ai-family-chatui",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        },
        {
          "name": "family_member_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "family_member_id",
            "claim.name": "family_member_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "lin-dad",
      "enabled": true,
      "email": "dad@ai-family.local",
      "firstName": "林",
      "lastName": "爸爸",
      "credentials": [
        {
          "type": "password",
          "value": "dev-pass-1234",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ],
      "attributes": {
        "family_member_id": [
          "member-dad"
        ]
      }
    },
    {
      "username": "lin-mom",
      "enabled": true,
      "email": "mom@ai-family.local",
      "firstName": "林",
      "lastName": "妈妈",
      "credentials": [
        {
          "type": "password",
          "value": "dev-pass-1234",
          "temporary": false
        }
      ],
      "realmRoles": [
        "adult"
      ],
      "attributes": {
        "family_member_id": [
          "member-mom"
        ]
      }
    },
    {
      "username": "duoduo",
      "enabled": true,
      "email": "duoduo@ai-family.local",
      "firstName": "朵朵",
      "lastName": "林",
      "credentials": [
        {
          "type": "password",
          "value": "dev-pass-1234",
          "temporary": false
        }
      ],
      "realmRoles": [
        "kid"
      ],
      "attributes": {
        "family_member_id": [
          "member-go-1"
        ]
      }
    },
    {
      "username": "yangyang",
      "enabled": true,
      "email": "yangyang@ai-family.local",
      "firstName": "阳阳",
      "lastName": "林",
      "credentials": [
        {
          "type": "password",
          "value": "dev-pass-1234",
          "temporary": false
        }
      ],
      "realmRoles": [
        "kid"
      ],
      "attributes": {
        "family_member_id": [
          "member-go-2"
        ]
      }
    }
  ]
}
