# 本地起栈密钥模板 —— 复制为 infra/.env（gitignored）后填值。compose.dev.yaml 引用。
# 切勿提交真实密钥（02 §5 / ADR-013：secrets 永不进代码路径）。

# PostgreSQL
PG_PASSWORD=postgres

# RabbitMQ
RABBITMQ_USER=aifam
RABBITMQ_PASSWORD=aifam

# Keycloak admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# LiteLLM —— 厂商 key 仅在此（BUG-003）
LITELLM_MASTER_KEY=sk-dev-master-change-me
DEEPSEEK_API_KEY=
KIMI_API_KEY=
ANTHROPIC_API_KEY=

# Langfuse
LANGFUSE_NEXTAUTH_SECRET=dev-secret-change-me
LANGFUSE_SALT=dev-salt-change-me

# MinIO
MINIO_USER=aifam
MINIO_PASSWORD=aifam-dev-secret

# Langfuse 项目 key（dev 自举）+ LiteLLM→Langfuse 回调（占位，本地 dev 用）
LANGFUSE_INIT_ORG_ID=aifam
LANGFUSE_INIT_PROJECT_ID=aifam-dev
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-dev-change-me
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-dev-change-me
LANGFUSE_INIT_USER_EMAIL=dev@ai-family.local
LANGFUSE_INIT_USER_PASSWORD=change-me
LANGFUSE_PUBLIC_KEY=pk-lf-dev-change-me
LANGFUSE_SECRET_KEY=sk-lf-dev-change-me
